{
  "name": "openclaw-notion",
  "version": "1.0.0",
  "description": "Native Notion integration for OpenClaw — 9 tools with markdown-first editing and multi-agent workspace isolation.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "keywords": ["openclaw", "notion", "plugin", "ai-agent", "markdown"],
  "author": "Octavian Tocan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OctavianTocan/openclaw-notion.git"
  },
  "dependencies": {
    "@notionhq/client": "^5.18.0",
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "openclaw": "^2026.4.15",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  }
}