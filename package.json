{
  "name": "openclaw-notion",
  "version": "1.0.0",
  "description": "Native Notion integration for OpenClaw — 17 tools with markdown-first editing, sync, and multi-agent workspace isolation.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "keywords": [
    "openclaw",
    "notion",
    "plugin",
    "ai-agent",
    "markdown"
  ],
  "author": "Octavian Tocan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OctavianTocan/openclaw-notion.git"
  },
  "dependencies": {
    "@notionhq/client": "^5.18.0",
    "@sinclair/typebox": "^0.34.49",
    "better-sqlite3": "^12.9.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "openclaw": "^2026.4.15",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  }
}
